# ===========================================================
# SECRETS & RUNTIME
# ===========================================================

# Ansible vault — real secrets, never commit
tacacs-ng/roles/tac_plus_ng_deploy/vars/vault.yml
# Vault backups created by configure-users
tacacs-ng/roles/tac_plus_ng_deploy/vars/vault.yml.bak.*

# Runtime variables saved by install.sh
tacacs-ng/vars.env

# Ansible inventory (generated by install.sh, contains host IPs)
tacacs-ng/inventory/

# ===========================================================
# ANSIBLE
# ===========================================================
*.retry

# ===========================================================
# MARKDOWN — ignore all, then allow specific files
# ===========================================================
*.md
!README.md
!USAGE.md
# Allow README/USAGE in subdirectories too
!**/README.md
!**/USAGE.md

# ===========================================================
# PYTHON
# ===========================================================
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

